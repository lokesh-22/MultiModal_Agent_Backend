APP_NAME=Agentic Multimodal Assistant
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

GEMINI_API_KEY=
GROQ_API_KEY=
LLM_PROVIDER=hybrid
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.3-70b-versatile

WHISPER_MODEL=small
OCR_PROVIDER=paddleocr
OCR_TEXT_MIN_CHARS=60
OCR_RENDER_ZOOM=2.5
MAX_UPLOAD_SIZE_MB=50